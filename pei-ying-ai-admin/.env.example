# ============================================================
# 生产环境配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# 数据库（Render/Railway 会自动注入 DATABASE_URL，无需手动设置）
# 本地 VPS 部署时使用以下配置：
DB_USER=peiying
DB_PASSWORD=your_secure_password_here
DB_NAME=peiying_ai

# 或直接使用完整连接字符串（优先级高于上面的配置）
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database

# 安全密钥（生产环境必须更换！可用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
SECRET_KEY=change-this-to-a-random-secret-key

# 调试模式（生产环境设为 false）
DEBUG=false

# 自动初始化种子数据（首次启动时自动创建测试数据）
AUTO_SEED=true

# CORS 允许的源（* 表示允许所有，生产环境建议填具体域名）
CORS_ORIGINS=*

# OpenAI API Key（可选，不填则 AI 辅助功能不可用，其他功能正常）
OPENAI_API_KEY=

# 服务端口（VPS 部署时使用）
PORT=80
